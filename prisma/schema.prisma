generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Fund {
  id         String        @id @db.VarChar(10)
  name       String        @db.Text
  sharePrice Decimal       @db.Decimal(12, 2)
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @db.Timestamptz(6)

  members    Member[]
  ledgers    MonthlyLedger[]
  winners    WinnerRecord[]
}

model Member {
  id         String   @db.VarChar(10)
  fundId     String   @db.VarChar(10)
  name       String   @db.Text
  contact    String   @default("") @db.Text
  shares     Int
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  fund       Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@id([fundId, id])
}

model MonthlyLedger {
  fundId     String   @db.VarChar(10)
  month      String   @db.Text
  done       Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  fund       Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@id([fundId, month])
}

model LedgerEntry {
  fundId     String   @db.VarChar(10)
  month      String   @db.Text
  memberId   String   @db.VarChar(10)
  paid       Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@id([fundId, month, memberId])
}

model WinnerRecord {
  id           String   @id @db.VarChar(10)
  fundId       String   @db.VarChar(10)
  month        String   @db.Text
  recordDate   DateTime @db.Timestamptz(6)
  amount       Decimal  @db.Decimal(12, 2)
  winners      String[]
  winnerIds    String[] @default([])
  winnerDetails Json    @default("[]")
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  fund         Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
}

model BhishiFund {
  id                 String   @id @db.VarChar(10)
  userId             String   @db.VarChar(10)
  name               String   @db.Text
  sharePrice         Decimal  @db.Decimal(12, 2)
  bonusPool          Decimal  @default(0) @db.Decimal(12, 2)
  totalUchalInterest Decimal  @default(0) @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)

  members            BhishiMember[]
  months             BhishiMonth[]
}

model BhishiMember {
  id         String   @db.VarChar(10)
  bhishiId   String   @db.VarChar(10)
  name       String   @db.Text
  contact    String   @default("") @db.Text
  shares     Int
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  fund       BhishiFund @relation(fields: [bhishiId], references: [id], onDelete: Cascade)

  @@id([bhishiId, id])
}

model BhishiMonth {
  bhishiId           String    @db.VarChar(10)
  monthNumber        Int
  carryForwardAmount Decimal   @default(0) @db.Decimal(12, 2)
  winnerShareId      String?   @db.VarChar(10)
  winnerName         String?   @db.Text
  winningBid         Decimal?  @db.Decimal(12, 2)
  payout             Decimal?  @db.Decimal(12, 2)
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6)

  fund               BhishiFund @relation(fields: [bhishiId], references: [id], onDelete: Cascade)

  @@id([bhishiId, monthNumber])
}

model BhishiAttendance {
  bhishiId    String   @db.VarChar(10)
  monthNumber Int
  memberId    String   @db.VarChar(10)
  paid        Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@id([bhishiId, monthNumber, memberId])
}

model BhishiUchal {
  id             String   @id @db.VarChar(10)
  bhishiId       String   @db.VarChar(10)
  monthNumber    Int
  memberId       String   @db.VarChar(10)
  memberName     String   @db.Text
  amount         Decimal  @db.Decimal(12, 2)
  interestRate   Decimal  @db.Decimal(6, 2)
  monthlyInterest Decimal @db.Decimal(12, 2)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)
}

model BhishiUchalGuarantor {
  uchalId           String   @db.VarChar(10)
  guarantorMemberId String   @db.VarChar(10)
  orderIndex        Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  @@id([uchalId, guarantorMemberId])
}

model BhishiBoliGuarantor {
  bhishiId         String   @db.VarChar(10)
  monthNumber      Int
  guarantorShareId String   @db.VarChar(10)
  orderIndex       Int      @default(0)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)

  @@id([bhishiId, monthNumber, guarantorShareId])
}

model AppUser {
  id           String   @id @db.VarChar(10)
  email        String   @unique @db.Text
  passwordHash String   @db.Text
  fullName     String   @db.Text
  orgName      String?  @db.Text
  contact      String   @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  sessions     AppSession[]
}

model AppSession {
  id        String   @id @db.VarChar(10)
  userId    String   @db.VarChar(10)
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
